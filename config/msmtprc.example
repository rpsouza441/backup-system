# Configuração msmtp para envio de email
# Arquivo: /etc/msmtprc
# 
# INSTRUÇÕES DE INSTALAÇÃO:
#
# 1. Instalar msmtp:
#    sudo apt install msmtp msmtp-mta
#
# 2. Copiar este arquivo para /etc/msmtprc:
#    sudo cp /opt/backup-system/config/msmtprc.example /etc/msmtprc
#    sudo chmod 600 /etc/msmtprc
#
# 3. Editar com suas credenciais reais
#
# 4. Testar envio:
#    echo "Teste" | msmtp seu_email@gmail.com
#

# Configurações globais
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        /var/log/msmtp.log

# Conta Gmail (padrão)
account        gmail
host           smtp.gmail.com
port           587
from           rpsouzati@gmail.com
user           rpsouzati@gmail.com
password       zgmkrcnukpzbgckw

# Definir gmail como conta padrão
account default : gmail
