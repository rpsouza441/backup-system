# Backup System - Configuração
# ============================================================================
# INSTRUÇÕES: Copie este arquivo para backup.conf e edite com seus valores
#   cp backup.conf.example backup.conf
# ============================================================================

# =============================================================================
# PATHS
# =============================================================================
# Diretório de logs do sistema
LOG_DIR="/var/log/backup-system"

# Diretório fonte dos dados a fazer backup
# Exemplo: /mnt/dados, /home/user/dados, etc
DATA_SOURCE="/caminho/para/seus/dados"

# Diretório destino para armazenar os backups
# Deve estar em um disco/partição separada do fonte
DATA_DEST="/caminho/destino/backup"

# =============================================================================
# STORAGES A MONTAR
# Formato: UUID:MOUNT_POINT:LABEL:CRITICAL
# CRITICAL = 1 se falha deve abortar backup, 0 se pode continuar
#
# Para obter o UUID de um disco, use:
#   sudo blkid /dev/sdX1
# =============================================================================
STORAGES=(
    # Formato: UUID:PONTO_MONTAGEM:LABEL:CRITICO
    # Exemplo com 2 discos:
    "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:/mnt/disco1:disco1:1"
    "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:/mnt/disco2:disco2:0"
)

# =============================================================================
# ONEDRIVE MOUNTS
# Formato: REMOTE_PATH:LOCAL_PATH:MODE
# MODE = writes | readonly | full
#
# Configure primeiro o rclone:
#   rclone config
# =============================================================================
ONEDRIVE_MOUNTS=(
    "REMOTE-FOLDER:/MOUNT-POINT:writes"
    "Pictures/Fotos:/FOTOS:readonly"
)

# =============================================================================
# RETENÇÃO E LIMPEZA
# =============================================================================
TAR_RETENTION_DAYS=7       # Dias para manter TARs
DAILY_BACKUP_RETENTION=5   # Dias para manter pastas diárias do rsync  
LOG_RETENTION_DAYS=60      # Dias para manter logs

# =============================================================================
# RSYNC
# =============================================================================
# Arquivo com padrões de exclusão para rsync (um por linha)
# Crie um arquivo com os padrões a ignorar (um por linha)
RSYNC_EXCLUDE_FILE="/caminho/destino/backup/EXCLUDE"

# =============================================================================
# DOCKER
# =============================================================================
DOCKER_STOP_TIMEOUT=10     # Segundos para aguardar containers pararem

# =============================================================================
# TIMEOUTS
# =============================================================================
UUID_CHECK_ATTEMPTS=6      # Tentativas para encontrar UUID
UUID_CHECK_INTERVAL=10     # Segundos entre tentativas
RCLONE_HEALTH_TIMEOUT=30   # Timeout para verificar saúde do rclone
TAR_COPY_TIMEOUT=300       # Timeout para copiar TAR (5 min)
TAR_COPY_RETRIES=3         # Tentativas de cópia do TAR
