# Backup System - Configuração
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para backup.conf
#    cp config/backup.conf.example config/backup.conf
# 2. Ajuste os caminhos, UUIDs e remotes conforme o seu ambiente
# 3. Garanta que seus pontos de montagem e o rclone já estejam configurados
# ============================================================================

# =============================================================================
# PATHS
# =============================================================================
# Diretório de logs do sistema
LOG_DIR="/var/log/seu-backup"

# Diretório fonte dos dados a fazer backup
# Exemplo: /mnt/dados, /srv/dados, /home/user/dados
DATA_SOURCE="/caminho/da/origem"

# Diretório destino para armazenar o backup diário via rsync
# Deve estar em outro disco/partição, com espaço suficiente
DATA_DEST="/caminho/do/destino"

# =============================================================================
# STORAGES A MONTAR
# Formato: UUID:MOUNT_POINT:LABEL:CRITICAL
# CRITICAL = 1 se falha deve abortar backup, 0 se pode continuar
#
# Para descobrir os UUIDs:
#   sudo blkid
# ou
#   ls -l /dev/disk/by-uuid/
# =============================================================================
STORAGES=(
    # Exemplo com 4 storages:
    "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:/mnt/disco-a:disco-a:1"
    "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:/mnt/disco-b:disco-b:0"
    "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:/mnt/disco-c:disco-c:1"
    "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:/mnt/disco-d:disco-d:1"
)

# =============================================================================
# ONEDRIVE MOUNTS
# Formato: REMOTE_PATH:LOCAL_PATH:MODE
# MODE = writes | readonly | full
#
# Antes de usar, configure o remote no rclone:
#   rclone config
# =============================================================================
ONEDRIVE_MOUNTS=(
    "remote-backup:/mnt/nuvem-backup:writes"
    "remote-readonly:/mnt/nuvem-leitura:readonly"
    "remote-sync:/mnt/nuvem-sync:writes"
)

# =============================================================================
# RETENÇÃO E LIMPEZA
# =============================================================================
TAR_RETENTION_DAYS=7       # Dias para manter TARs locais e remotos
DAILY_BACKUP_RETENTION=5   # Dias para manter pastas diárias do rsync
LOG_RETENTION_DAYS=60      # Dias para manter logs

# =============================================================================
# RSYNC
# =============================================================================
# Arquivo com padrões de exclusão do rsync (um por linha)
# Exemplo de conteúdo:
#   *.tmp
#   cache/
#   node_modules/
RSYNC_EXCLUDE_FILE="/caminho/do/destino/EXCLUDE"

# =============================================================================
# DOCKER
# =============================================================================
# Tempo para aguardar o shutdown gracioso dos containers antes do backup
DOCKER_STOP_TIMEOUT=10

# =============================================================================
# TIMEOUTS
# =============================================================================
UUID_CHECK_ATTEMPTS=6      # Tentativas para encontrar UUID durante o boot
UUID_CHECK_INTERVAL=10     # Segundos entre tentativas
RCLONE_HEALTH_TIMEOUT=30   # Timeout para verificar saúde do rclone
TAR_COPY_TIMEOUT=300       # Timeout para copiar TAR
TAR_COPY_RETRIES=3         # Tentativas de cópia do TAR
