# =============================================================================
# Report System - Configuração
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para report.conf
#    cp config/report.conf.example config/report.conf
# 2. Configure o destinatário do email
# 3. Opcionalmente, configure um webhook como fallback
# 4. Garanta que o /etc/msmtprc esteja configurado se quiser envio por email
# ============================================================================

# =============================================================================
# EMAIL
# =============================================================================
# Destinatário do email de relatório
# O remetente/SMTP é configurado em /etc/msmtprc
EMAIL="seu_email@gmail.com"

# =============================================================================
# WEBHOOK (alternativo ao email)
# =============================================================================
# Pode ser usado como fallback para Slack, Discord, Mattermost, etc.
# Deixe vazio para desabilitar
WEBHOOK_URL=""

# =============================================================================
# ALERTAS SMART
# Níveis: INFO, WARNING, CRITICAL
# - INFO: alertas aparecem no relatório mas NÃO mudam status do título
# - WARNING: alertas SMART elevam status para WARNING no título
# - CRITICAL: apenas status diferente de PASSED/OK eleva para CRÍTICO
# =============================================================================
SMART_ALERT_LEVEL="WARNING"

# =============================================================================
# DIRETÓRIOS
# =============================================================================
# Diretório onde os logs do backup são gravados
LOG_DIR="/var/log/seu-backup"

# Diretório onde os relatórios gerados serão salvos
REPORT_DIR="/var/log/seu-backup/reports"

# =============================================================================
# RETENÇÃO
# =============================================================================
# Dias para manter relatórios antigos
REPORT_RETENTION_DAYS=30
